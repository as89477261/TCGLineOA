		<!-- Tcg PhomKhum-->
		<add key="emailTemplateBodyPromKhum"
		  value="" />
		<add key="emailSubjectPhomKhum"
		  value="แจ้งผู้ลงทะเบียนโครงการพร้อมค้ำพร้อมช่วย (สำหรับทดสอบ UAT)" />
		<!-- Tcg PhomKhum SET TO Y : Any Set N  USE PAGE V5-->
		<add key="sendMailPromKhum" value="Y" />

	</appSettings>
	<!--
    For a description of web.config changes see http://go.microsoft.com/fwlink/?LinkId=235367.

    The following attributes can be set on the <httpRuntime> tag.
      <system.Web>
        <httpRuntime targetFramework="4.8" />
      </system.Web>
  -->
	<system.web>
		<compilation debug="true" targetFramework="4.8" />
		<pages controlRenderingCompatibilityVersion="4.0" />
	</system.web>

	<system.serviceModel>
		<bindings>
			<basicHttpBinding>
				<binding name="RegisterControllerSoap" />
			</basicHttpBinding>
		</bindings>
		<client>
			<endpoint
			  address="http://demo.tcg.or.th/HealthCheck_SMEs_Stimulate_Campaign_UAT/API/RegisterController.asmx"
			  binding="basicHttpBinding"
			  bindingConfiguration="RegisterControllerSoap"
			  contract="RegisterControllerService.RegisterControllerSoap"
			  name="RegisterControllerSoap" />
		</client>
	</system.serviceModel>
</configuration>
