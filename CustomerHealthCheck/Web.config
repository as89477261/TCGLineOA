<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<configSections>
		<!-- log4net START here-->
		<section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler,log4net" />
		<!-- log4net STOP here-->
	</configSections>
	<log4net>
		<root>
			<level value="ALL" />
			<appender-ref ref="MyTxt" />
		</root>
		<appender name="MyTxt" type="log4net.Appender.RollingFileAppender">
			<file value="D:\LOG\HC_" />
			<!-- This is file path to save the log. Note : don't put file extension.-->
			<appendToFile value="true" />
			<datePattern value="yyyy-MM-dd.\tx\t" />
			<!-- This is date format for file name to save the log.-->
			<rollingStyle value="Date" />
			<param name="StaticLogFileName" value="false" />
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="%d %-8ndc %-5thread %-5level : %logger : %message %timestampms %n" />
			</layout>
		</appender>
	</log4net>
	<appSettings>
		<add key="DB_CustomerHealthCheck"
		  value="server=192.168.8.13;uid=AppUISub1;pwd=UATUIS1!$gD6#;database=DB_CustomerHealthCheck;application name=CustomerHealthCheck;Connection Timeout=1;Max Pool Size=3000;" />
		<add key="DB_SMEClinic"
		  value="server=192.168.8.13;uid=AppUISub1;pwd=UATUIS1!$gD6#;database=DB_SMEClinic;application name=CustomerHealthCheck;Connection Timeout=1;Max Pool Size=3000;" />
		<add key="logging" value="Y" />
		<add key="lineMenuURL" value="https://demo.tcg.or.th/LineOAFront_UAT/index" />
		<add key="TCGContactURL" value="https://www.tcg.or.th" />
		<add key="ServiceURL" value="https://tcg-api.sbcg.or.th/tcg_api_center/api" />
		<add key="EmailTemplateHeader" value="แจ้งผลการตรวจสุขภาพทางการเงิน" />
		<add key="emailTemplateBody"
		  value="" />
		<add key="infoType" value="HealthCheck" />
		<add key="subInfoType" value="SMEsStimulateCampaign" />


		<!-- Tcg API-->
		<add key="apiBaseURL" value="https://tcg-api.sbcg.or.th/tcg_api_center/api" />
		<!--<add
    key="apiTCGOAuthen" value="https://tcg-api.sbcg.or.th/tcg_api_center/api/Account/Login"/>-->
		<add key="apiTCGOAuthen" value="https://tcg-api.sbcg.or.th/tcg_api_center/api/Account/Login" />
		<!--<add
    key="apiDSCRURL" value="https://chatclinic.tcg.or.th/apidscr"/>-->
		<!--<add
    key="apiDSCRURL" value="https://localhost:44364"/>-->
		<add key="apiTCGScore" value="https://chatclinic.tcg.or.th/apidscr" />
		<add key="apiTCGScore" value="https://localhost:44364" />
		<add key="apiUsername" value="Service_RestCAPI_UserDOTNET" />
