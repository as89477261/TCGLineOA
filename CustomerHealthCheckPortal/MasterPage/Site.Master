        <asp:HiddenField runat="server" ID="hddDirectAppTcgRegisterRewardURL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddTcgRegisterDopa" ClientIDMode="Static" />

        <asp:HiddenField runat="server" ID="hddliffCampaignConfigUrl" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddNewTCGPortalURL" ClientIDMode="Static" />
        


 
        <asp:ContentPlaceHolder ID="ContentPlaceHolder1" runat="server">
        </asp:ContentPlaceHolder>
    </form>
    <script src="<%= ResolveClientUrl("~/scripts/BaseJS/GlobalParameter.js") + "?v=" + DateTime.Now.ToString("ddMMyyyyHHmmss") %>"></script>
    <script src="<%= ResolveClientUrl("~/scripts/BaseJS/SiteMap.js") + "?v=" + DateTime.Now.ToString("ddMMyyyyHHmmss") %>"></script>
