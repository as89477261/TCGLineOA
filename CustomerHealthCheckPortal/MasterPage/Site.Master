        <asp:HiddenField runat="server" ID="hddHomeUrl" ClientIDMode="Static" />

        <asp:HiddenField runat="server" ID="hddCustomerHealthCheckURL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddCustomerHealthCheckPGS10URL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddPromKhumHealthCheckURL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddSMEsPickUpHealthCheckUrl" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddSMEsStimulateCampaign" ClientIDMode="Static" />

        <asp:HiddenField runat="server" ID="hddDebtURL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddProductURL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddNDIDURL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddIdentifyURL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddEventURL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddRegisterURL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddQuestionaireURL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddAttentionURL" ClientIDMode="Static" />

        <asp:HiddenField runat="server" ID="hddRegisterDebtFormURL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddRegisterEventFormURL" ClientIDMode="Static" />

        <asp:HiddenField runat="server" ID="hddNDIDEFormURL" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddContactDoctorURL" ClientIDMode="Static" />

        <asp:HiddenField runat="server" ID="hddIsCheckDopa" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddAPIPartialCode" ClientIDMode="Static" />

        <asp:HiddenField runat="server" ID="hddGoogleTagCode" ClientIDMode="Static" />
        <asp:HiddenField runat="server" ID="hddGoogleAnalyticCode" ClientIDMode="Static" />

        <asp:HiddenField runat="server" ID="hddPDPAConsentPoint" ClientIDMode="Static" />


        <asp:HiddenField runat="server" ID="hddDirectAppTcgOrURL" ClientIDMode="Static" />
